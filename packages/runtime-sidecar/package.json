{
  "name": "@qeeclaw/runtime-sidecar",
  "version": "0.1.0",
  "description": "Local runtime sidecar reference implementation for QeeClaw platform capabilities",
  "license": "Apache-2.0",
  "author": "QeeClaw Team",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "qeeclaw-sidecar": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "docs"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/longxipinglq5/qeeclaw-sdk.git",
    "directory": "packages/runtime-sidecar"
  },
  "homepage": "https://github.com/longxipinglq5/qeeclaw-sdk#readme",
  "bugs": {
    "url": "https://github.com/longxipinglq5/qeeclaw-sdk/issues"
  },
  "keywords": [
    "qeeclaw",
    "sidecar",
    "runtime",
    "desktop",
    "local-runtime",
    "reference-implementation"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run build && node --test tests/**/*.test.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.2.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.23.0"
}
