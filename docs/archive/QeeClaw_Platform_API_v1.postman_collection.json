          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action_type\": \"SDK_DEMO\",\n  \"title\": \"QeeClaw customer integration smoke test\",\n  \"module\": \"POSTMAN\",\n  \"path\": \"/api/platform/models\",\n  \"params\": \"team_id={{teamId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/platform/audit/events"
          }
        },
        {
          "name": "Get Audit Summary",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/platform/audit/summary?scope=mine",
