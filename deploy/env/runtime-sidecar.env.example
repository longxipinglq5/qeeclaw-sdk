# QeeClaw Runtime Sidecar 示例配置

# 控制面地址
QEECLAW_CONTROL_PLANE_URL=https://your-qeeclaw-host

# Sidecar 本地监听
QEECLAW_SIDECAR_HOST=127.0.0.1
QEECLAW_SIDECAR_PORT=21736
QEECLAW_SIDECAR_AUTH_TOKEN=replace-with-a-local-sidecar-token
QEECLAW_SIDECAR_ALLOW_REMOTE=false

# 是否启动时自动托管本地 gateway
QEECLAW_SIDECAR_START_GATEWAY=false
QEECLAW_SIDECAR_AUTO_BOOTSTRAP=true

# 本地状态目录
QEECLAW_STATE_DIR=$HOME/.qeeclaw
QEECLAW_AUTH_STATE_FILE=$HOME/.qeeclaw/auth-state.json
QEECLAW_SIDECAR_STATE_DIR=$HOME/.qeeclaw/sidecar

# 本地 Gateway 启动方式
QEECLAW_GATEWAY_COMMAND=node
QEECLAW_GATEWAY_ARGS=["/opt/qeeclaw/gateway/openclaw.mjs","gateway","--bind","lan","--port","18789","--allow-unconfigured"]
QEECLAW_GATEWAY_WORKDIR=/opt/qeeclaw/gateway
QEECLAW_GATEWAY_WS_URL=ws://127.0.0.1:18789

# 设备与主机信息
QEECLAW_DEVICE_NAME=QeeClaw Desktop Node
QEECLAW_HOSTNAME=demo-mac
QEECLAW_OS_INFO=macOS 15
