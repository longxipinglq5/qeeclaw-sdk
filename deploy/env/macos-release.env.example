# QeeClaw macOS 发布示例配置
# 使用方式：
#   source sdk/deploy/env/macos-release.env.example && ./scripts/package-openclaw.sh
# 说明：
#   该模板仅适用于主平台 monorepo 中的桌面宿主打包流程。
#   导出的 SDK 公开仓不包含 package-openclaw.sh 与 vendor/openclaw。

export SIGN_IDENTITY="Developer ID Application: Your Company (TEAMID)"
export BUILD_CONFIG=release

# 可选版本参数
export SET_VERSION="1.1.0"
export EMBEDDED_NODE_VERSION="v22.12.0"

# 可选公证参数
export APPLE_ID="developer@example.com"
export APPLE_TEAM_ID="TEAMID"
export APPLE_APP_PASSWORD="xxxx-xxxx-xxxx-xxxx"
