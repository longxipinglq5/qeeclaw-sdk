# QeeClaw Gateway 服务器示例配置

# 镜像与端口
QEECLAW_GATEWAY_IMAGE=openclaw:latest
QEECLAW_GATEWAY_PORT=18789

# 本地挂载目录
QEECLAW_GATEWAY_CONFIG_DIR=./config
QEECLAW_GATEWAY_WORKSPACE_DIR=./workspace

# 基础运行参数
TZ=Asia/Shanghai
OPENCLAW_GATEWAY_TOKEN=replace-with-strong-random-token
OPENCLAW_LOG_LEVEL=info

# 交付记录字段
QEECLAW_GATEWAY_PUBLIC_URL=wss://gateway.example.com
QEECLAW_GATEWAY_SERVER_NAME=gateway.example.com
